UIS.InputChanged:Connect(function(i)
    if not scD or i.UserInputType~=Enum.UserInputType.Touch then return end
    local dy=i.Position.Y-scLY;local dx=math.abs(i.Position.X-scSX)
    if not scOk then if math.abs(dy)>dx+2 then scOk=true elseif dx>math.abs(dy)+2 then scD=false;return end end
