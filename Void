local SF="ApexV3.txt"
local SK={"VE","VM","VB","VS","VC","VA","VLA","VLB","VSC","VEV","VER","VES","VGH","VGI","DE","DT","DR","YR","SI","FI","FE","GS","OE","OM","OS","OB","OJ","OH","OMIN","OMAX","OP","SE","SW","IJ","NC","LG","GV","AO","AM","AI","AR","AOS"}
local function sav()
    local p={}
    for _,k in ipairs(SK)do local v=C[k];if v~=nil then table.insert(p,k.."="..(type(v)=="boolean"and(v and"T"or"F")or tostring(v)))end end
    pcall(function()writefile(SF,table.concat(p,"\n"))end)
end
local function lod()
    local ok,s=pcall(function()return readfile(SF)end)
    if not ok or not s or s=="" then return false end
    for line in s:gmatch("[^\n]+")do
        local k,v=line:match("^([^=]+)=(.+)$")
        if k and v then if v=="T" then C[k]=true elseif v=="F" then C[k]=false else local n=tonumber(v);if n then C[k]=n else C[k]=v end end end
    end
    return true
end

