local function upGnd()
    local rp=RaycastParams.new();rp.FilterType=Enum.RaycastFilterType.Exclude
    if LP.Character then rp.FilterDescendantsInstances={LP.Character}end
    local r=workspace:Raycast(Vector3.new(0,1000,0),Vector3.new(0,-2000,0),rp)
    if r then gY=r.Position.Y+3 end
end

local function dDir(t)
    local nx,nz,amp,fr=0,0,1,0.0001
    for _=1,4 do nx=nx+math.noise(t*fr,0)*amp;nz=nz+math.noise(0,t*fr)*amp;fr=fr*2.37;amp=amp*0.5 end
    local len=math.sqrt(nx*nx+nz*nz)
    if len<0.001 then local a=t*3.14*0.1;return math.cos(a),math.sin(a)end
    return nx/len,nz/len
end

local function sVd(dt)
    local m=C.VM;local spd=C.VS*1e6;local yb=C.VA*1e12;local p=Vector3.new(vx,yb+vy,vz)
    if m=="Stable" then return p
    elseif m=="Drift" then
        local dx,dz=dDir(el);local ch=C.VC*0.01
        vdx=vdx+(dx-vdx)*ch*dt*10;vdz=vdz+(dz-vdz)*ch*dt*10
        vx=vx+vdx*spd*dt;vz=vz+vdz*spd*dt
        vy=vy+vyd*spd*0.4*dt;if math.abs(vy)>=C.YR*1e9 then vyd=-vyd end
        return Vector3.new(vx,yb+vy,vz)
    elseif m=="Chaotic" then vx=vx+(math.random()-.5)*spd*dt*5;vz=vz+(math.random()-.5)*spd*dt*5;return Vector3.new(vx,yb+vy,vz)
    elseif m=="Circle" then local r=1e9;return Vector3.new(vx+math.cos(el*2)*r,yb+vy,vz+math.sin(el*2)*r)
    elseif m=="Spiral" then local r=1e9*(1+math.sin(el));return Vector3.new(vx+math.cos(el*3)*r,yb+vy,vz+math.sin(el*3)*r)
    elseif m=="Lissajous" then local r=2e9;return Vector3.new(vx+math.sin(el*C.VLA)*r,yb+vy,vz+math.sin(el*C.VLB)*r)
    elseif m=="Perlin Noise" then local t=el*0.1;return Vector3.new(vx+math.noise(t,0)*5e9,yb+vy,vz+math.noise(0,t)*5e9)
    elseif m=="Flicker Void" then local fi=C.FI*0.001;return(tick()%(fi*2)<fi)and Vector3.new(vx,yb,vz)or Vector3.new(-vx,yb+1e9,-vz)
    elseif m=="Gravity Well" then local r=C.GS*1e6*(1+math.sin(el*0.5));return Vector3.new(vx+math.cos(el*0.5)*r,yb+math.sin(el*0.35)*r,vz+math.sin(el*0.5)*r)
    elseif m=="Helix" then local r=1e9;local t=el*2;return Vector3.new(vx+math.cos(t)*r,yb+vy+math.sin(t*0.5)*r,vz+math.sin(t)*r)
    elseif m=="Figure 8" then local r=1.5e9;local t=el*1.5;return Vector3.new(vx+math.sin(t)*r,yb+vy,vz+math.sin(t)*math.cos(t)*r)
    elseif m=="Tornado" then local r=2e9*math.abs(math.sin(el));local t=el*5;return Vector3.new(vx+math.cos(t)*r,yb+math.sin(el*2)*1e9,vz+math.sin(t)*r)
    elseif m=="Butterfly" then local t=el;local r=(math.exp(math.sin(t))-2*math.cos(4*t)+math.sin((2*t-math.pi)/24)^5)*5e8;return Vector3.new(vx+math.sin(t)*r,yb+math.cos(t)*r,vz+math.sin(t*0.5)*r)
    elseif m=="Double Helix" then local r=1e9;local t=el*3;local o=(tick()%1<0.5)and 1 or -1;return Vector3.new(vx+math.cos(t)*r*o,yb+math.sin(t)*5e8,vz+math.sin(t)*r*o)
    elseif m=="Chaotic Sphere" then local r=2e9;local t1,t2=el*2,el*1.3;return Vector3.new(vx+math.sin(t1)*math.cos(t2)*r,yb+math.sin(t1)*math.sin(t2)*r,vz+math.cos(t1)*r)
    elseif m=="Quantum Tunneling" then local r=1e11*(math.random()>.5 and 1 or -1);local j=Vector3.new((math.random()-.5)*2e9,(math.random()-.5)*2e8,(math.random()-.5)*2e9);return Vector3.new(vx+r,yb+j.Y,vz+r)+j
    elseif m=="Fractal Desync" then local t=el*5;local x=math.sin(t)+math.sin(t*2.1)/2+math.sin(t*3.2)/4;local z=math.cos(t)+math.cos(t*2.2)/2+math.cos(t*3.1)/4;return Vector3.new(vx+x*1e10,yb+math.sin(t*10)*1e9,vz+z*1e10)
    elseif m=="Extreme Desync" then local t=el*15;return Vector3.new(vx+math.sin(t)*1e12,yb+math.cos(t*1.5)*1e11,vz+math.cos(t)*1e12)
    elseif m=="Quantum Oscillation" then local t=el*50;local r=1e11*math.sin(t);return Vector3.new(vx+r,yb+math.cos(t)*1e10,vz+r)
    elseif m=="Frame Skip" then return(tick()%0.1<0.05)and Vector3.new(vx*2,yb+1e11,vz*2)or Vector3.new(vx,yb,vz)
    end
    return p
end

local function sSp(dt)
    gYT=gYT+dt;if gYT>5 then gYT=0;task.spawn(upGnd)end
    local nv=math.noise(el*0.8,42)
    spA=spA+spD*(1.5+nv*0.4)*3.5*dt
    if math.noise(el*0.3,7.7)>0.6 then spD=-spD end
    local r=C.DR*(0.5+0.5*math.abs(math.noise(el*0.5,0)))
    fGP=Vector3.new(spBX+math.cos(spA)*r,gY,spBZ+math.sin(spA)*r)
end

local function doFl()
    if inFl then return end;local h=gH();if not h then return end
    inFl=true;local sv=ivp
    pcall(function()h.CFrame=CFrame.new(fGP);h.AssemblyLinearVelocity=Vector3.new(0,-0.01,0)end)
    task.delay(0,function()
        local h2=gH();if h2 and C.VE then pcall(function()h2.CFrame=CFrame.new(sv);h2.AssemblyLinearVelocity=Vector3.zero end)end
        inFl=false
    end)
end

local function chkEv()
    if not C.VEV or veCD>0 then return end
    local evR=C.VER*1e9;local evS=C.VES*1e9
    for _,p in ipairs(Pl:GetPlayers())do
        if p~=LP and p.Character then
            local h=p.Character:FindFirstChild("HumanoidRootPart")
            local hm=p.Character:FindFirstChildOfClass("Humanoid")
            if h and hm and hm.Health>0 then
                local d=(h.Position-ivp).Magnitude
                if d<evR then
                    local aw=(ivp-h.Position);if aw.Magnitude>.1 then aw=aw.Unit;vx=vx+aw.X*evS*2;vz=vz+aw.Z*evS*2;veCD=0.05 end
                end
            end
        end
    end
end

local function lkVd(dt)
    if inFl then return end
    if veCD>0 then veCD=veCD-dt end
    chkEv();ivp=sVd(dt)
    local tp=ivp+Vector3.new(math.sin(tick()*100)*50,math.sin(tick()*70)*20,math.cos(tick()*130)*50)
    local h=gH();if not h then return end
    if C.VB=="Velocity" then pcall(function()h.AssemblyLinearVelocity=(tp-h.Position)*100 end)
    elseif C.VB=="CFrame only" then pcall(function()h.CFrame=CFrame.new(tp)end)
    elseif C.VB=="Hybrid" then pcall(function()h.CFrame=CFrame.new(tp);h.AssemblyLinearVelocity=Vector3.new(0,0.01,0)end)
    elseif C.VB=="Physics Bypass" then pcall(function()h.CFrame=CFrame.new(tp);h.AssemblyLinearVelocity=Vector3.new(math.random(-1,1),math.random(-1,1),math.random(-1,1))*1e5 end)
    else pcall(function()
        h.CFrame=CFrame.new(tp);h.AssemblyLinearVelocity=Vector3.zero;h.AssemblyAngularVelocity=Vector3.zero
        if math.random(1,8)==1 then h.AssemblyLinearVelocity=Vector3.new((math.random()-.5)*2e7,(math.random()-.5)*2e7,(math.random()-.5)*2e7)end
    end)end
    if C.DE then sSp(dt);deT=deT+dt;if deT>=C.DT*0.01 then deT=0;task.spawn(doFl)end end
end

local function startVoid()
    if vc then vc:Disconnect();vc=nil end
    local h=gH();if h then vx=h.Position.X;vz=h.Position.Z;spBX=vx;spBZ=vz;pcall(function()h:SetNetworkOwner(LP)end)end
    ivp=Vector3.new(vx,C.VA*1e12,vz);task.spawn(upGnd)
    vc=RS.Heartbeat:Connect(function(dt)if not C.VE then vc:Disconnect();vc=nil;return end;el=el+dt;lkVd(dt)end)
end
local function stopVoid()if vc then vc:Disconnect();vc=nil end end

-- ORBIT
local oA=0;local oc=nil;local cTg=nil
local function fTg()
    local best,bs=nil,-math.huge;local cp=workspace.CurrentCamera.CFrame.Position
    for _,p in ipairs(Pl:GetPlayers())do
        if p~=LP and p.Character then
            local hm=p.Character:FindFirstChildOfClass("Humanoid");local hr=p.Character:FindFirstChild("HumanoidRootPart")
            if hm and hr and hm.Health>0 then local sc=1/math.max((cp-hr.Position).Magnitude,1)*1000;if sc>bs then bs=sc;best=p end end
        end
    end
    return best
end
local function gOO()
    local m=C.OM;local rb=(C.OMIN*10000)+((C.OMAX*1e8)-(C.OMIN*10000))*0.5;local h=C.OH*1000;local t=oA
    if m=="Spiral" then local r=C.OMIN*10000+(el*100000)%(C.OMAX*1e8-C.OMIN*10000);return Vector3.new(math.cos(t)*r,h,math.sin(t)*r)
    elseif m=="Lissajous" then local rx=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*0.7;local rz=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*0.3;return Vector3.new(math.sin(t*3)*rx,h,math.sin(t*2)*rz)
    elseif m=="Helix" then return Vector3.new(math.cos(t)*rb,h+math.sin(t*2)*50000,math.sin(t)*rb)
    elseif m=="Figure 8" then return Vector3.new(math.sin(t)*rb,h,math.sin(t)*math.cos(t)*rb)
    elseif m=="Pulse" then local pr=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*(0.5+0.5*math.sin(el*5));return Vector3.new(math.cos(t)*pr,h,math.sin(t)*pr)
    elseif m=="Tornado" then local r=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*(0.3+0.7*math.abs(math.sin(el*2)));return Vector3.new(math.cos(t*3)*r,h+math.sin(el*10)*100000,math.sin(t*3)*r)
    elseif m=="Quantum Orbit" then local qr=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*(0.5+0.5*math.sin(el*13));local qp=math.sin(el*7)*math.pi;return Vector3.new(math.cos(t+qp)*qr,h+math.sin(qp*2)*50000,math.sin(t+qp)*qr)
    end
    local r=(C.OMIN*10000)+(C.OMAX*1e8-C.OMIN*10000)*(0.5+0.5*math.sin(el*0.3));return Vector3.new(math.cos(t)*r,h,math.sin(t)*r)
end
local function startOrbit()
    if oc then oc:Disconnect();oc=nil end
    local Cam=workspace.CurrentCamera
    oc=RS.Heartbeat:Connect(function(dt)
        if not C.OE then oc:Disconnect();oc=nil;return end
        if not cTg or not cTg.Character or not cTg.Character:FindFirstChild("HumanoidRootPart") then cTg=fTg()end
        if not cTg then return end
        local hr=cTg.Character:FindFirstChild("HumanoidRootPart");if not hr then return end
        local vel=hr.AssemblyLinearVelocity;local rp=hr.Position+vel*(C.OP*0.01)
        oA=oA+(C.OS*0.1)*dt;local off=gOO()
        local j=Vector3.new((math.random()-.5)*2*C.OJ,(math.random()-.5)*2*C.OJ,(math.random()-.5)*2*C.OJ)
        local tcf=CFrame.lookAt(rp+off+j,rp);local lf=cl(0.12+vel.Magnitude*0.004,0.12,0.45)
        pcall(function()Cam.CFrame=Cam.CFrame:Lerp(tcf,lf*(C.OB*0.1))end)
    end)
end
local function stopOrbit()if oc then oc:Disconnect();oc=nil end end

