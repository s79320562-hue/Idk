    scLY=i.Position.Y;local pg=tPs[cTab];if not pg then return end
    local cy=pg.Position.Y.Offset;local mu=-(pY[cTab]-(WH-54));if mu>=52 then return end
    pg.Position=UDim2.new(0,0,0,math.clamp(cy+dy,mu,52))
end)

