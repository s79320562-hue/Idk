-- ANTI ORBIT
local aoC=nil
local function stAO()
    if aoC then aoC:Disconnect();aoC=nil end
    aoC=RS.Heartbeat:Connect(function(dt)
        if not C.AO then aoC:Disconnect();aoC=nil;return end
        local h=gH();if not h then return end
        local m=C.AM;local inten=C.AI;local spd=C.AOS;local rad=C.AR
        local t=tick()
        if m=="Vector Jitter" then
            -- Rapid random velocity bursts that break orbit prediction
            if math.random(1,3)==1 then
                pcall(function()
                    h.AssemblyLinearVelocity=Vector3.new(
                        (math.random()-.5)*inten*spd,
                        (math.random()-.5)*inten*2,
                        (math.random()-.5)*inten*spd
                    )
                end)
                task.delay(0.04,function()
                    local h2=gH();if h2 then pcall(function()h2.AssemblyLinearVelocity=Vector3.new(0,h2.AssemblyLinearVelocity.Y,0)end)end
                end)
            end
        elseif m=="Phase Shift" then
            -- Teleport slightly every 0.1s in random direction
            if math.floor(t*10)~=math.floor((t-dt)*10) then
                pcall(function()
                    local off=Vector3.new((math.random()-.5)*rad,(math.random()-.5)*rad*.2,(math.random()-.5)*rad)
                    h.CFrame=h.CFrame+off
                end)
                task.delay(0.05,function()
                    local h2=gH();if h2 then pcall(function()h2.CFrame=h2.CFrame-Vector3.new((math.random()-.5)*rad*0.5,0,(math.random()-.5)*rad*0.5)end)end
                end)
            end
        elseif m=="Elastic Snap" then
            -- Snaps position back and forth rapidly
            local snap=(math.floor(t*spd*0.5)%2==0)
            pcall(function()
                local dir=Vector3.new(math.cos(t*3)*rad,math.sin(t*2)*rad*.1,math.sin(t*3)*rad)
                h.AssemblyLinearVelocity=snap and dir*10 or -dir*10
            end)
        elseif m=="Spin" then
            -- Rotates HRP rapidly so orbit camera spins
            pcall(function()
                h.CFrame=h.CFrame*CFrame.Angles(0,math.rad(spd*3),0)
            end)
        elseif m=="Desync Spiral" then
            -- Spiral velocity pattern that makes orbit prediction fail
            local ang=t*spd*.5
            pcall(function()
                h.AssemblyLinearVelocity=Vector3.new(
                    math.cos(ang)*inten*spd*.3,
                    math.sin(ang*.7)*inten*.5,
                    math.sin(ang)*inten*spd*.3
                )
            end)
            task.delay(0.06,function()
                local h2=gH();if h2 then pcall(function()h2.AssemblyLinearVelocity=Vector3.zero end)end
            end)
        elseif m=="Null Point" then
            -- Zero velocity + random CFrame offset so orbit loses lock
            pcall(function()h.AssemblyLinearVelocity=Vector3.zero end)
            if math.random(1,4)==1 then
                pcall(function()
                    h.CFrame=h.CFrame*CFrame.new((math.random()-.5)*rad*.5,0,(math.random()-.5)*rad*.5)
                end)
            end
        elseif m=="Ghost Step" then
            -- Alternate between two positions rapidly
            local flip=math.floor(t*spd*.4)%2==0
            pcall(function()
                local off=Vector3.new(math.cos(t)*rad*.3,0,math.sin(t)*rad*.3)
                h.CFrame=CFrame.new(h.Position+(flip and off or -off))
            end)
        end
    end)
end
local function spAO()if aoC then aoC:Disconnect();aoC=nil end end

