-- Scroll
local scD=false;local scLY=0;local scSX=0;local scOk=false
for _,pg in ipairs(tPs)do
    pg.InputBegan:Connect(function(i)if i.UserInputType==Enum.UserInputType.Touch then scD=true;scLY=i.Position.Y;scSX=i.Position.X;scOk=false end end)
    pg.InputEnded:Connect(function(i)if i.UserInputType==Enum.UserInputType.Touch then scD=false;scOk=false end end)
